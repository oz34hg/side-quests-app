rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    function groupMember(groupId) {
      return request.auth != null
        && exists(/databases/(default)/documents/groups/$(groupId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(groupId)).data.memberIds;
    }

    // Side-quest proof: only today’s assignee while quest is open; path includes calendar dayKey.
    match /groups/{groupId}/sideQuestByDay/{dayKey}/{fileName} {
      allow read: if request.auth != null;
      allow write: if groupMember(groupId)
        && exists(/databases/(default)/documents/groups/$(groupId)/days/$(dayKey))
        && request.auth.uid == firestore.get(/databases/(default)/documents/groups/$(groupId)/days/$(dayKey)).data.assigneeUserId
        && firestore.get(/databases/(default)/documents/groups/$(groupId)/days/$(dayKey)).data.sideQuestStatus == 'open'
        && fileName.matches('^' + request.auth.uid + '_.+');
    }

    // Legacy flat sideQuest paths (read-only; new uploads use sideQuestByDay).
    match /groups/{groupId}/sideQuest/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /groups/{groupId}/vlogs/{fileName} {
      allow read: if request.auth != null;
      allow write: if groupMember(groupId) && fileName.matches('^' + request.auth.uid + '_.+');
    }

    match /groups/{groupId}/chat/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if groupMember(groupId);
    }
  }
}
